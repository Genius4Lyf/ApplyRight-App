{
  "appId": "com.applyright.app",
  "appName": "ApplyRight",
  "webDir": "dist",
  "plugins": {
    "StatusBar": {
      "overlaysWebView": true,
      "style": "DARK",
      "backgroundColor": "#ffffff00"
    },
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#ffffff",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": true,
      "androidSpinnerStyle": "large",
      "spinnerColor": "#4f46e5"
    }
  }
}
